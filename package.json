{
  "name": "@askrjs/logos",
  "version": "0.0.1",
  "description": "Thin Askr wrappers for the Askr logo SVG set",
  "keywords": [
    "askr",
    "askrjs",
    "components",
    "logos",
    "svg"
  ],
  "homepage": "https://github.com/askrjs/askr-logos#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-logos/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-logos.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logos/*": {
      "types": "./dist/logos/*.d.ts",
      "import": "./dist/logos/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "npx rimraf node_modules dist",
    "build": "vp pack",
    "rebuild": "npm run clean && npm ci && npm run build",
    "dev": "vp pack --watch",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit && npm run test:checks && npm run test:exports",
    "test:checks": "vp test run -c vitest.test.checks.config.ts",
    "test:exports": "node tests/package-surface.js",
    "test:types": "tsc -p tsconfig.pack.json --noEmit",
    "test:unit": "vp test run -c vitest.config.ts"
  },
  "devDependencies": {
    "@askrjs/askr": "^0.0.40",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.30 <0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
